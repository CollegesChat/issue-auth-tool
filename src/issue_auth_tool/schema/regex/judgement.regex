(?x)^                         # 启用 verbose 模式，可以换行加注释
(?:                          # 外层非捕获分组，匹配三种情况之一
    del                      # del 开头
    (?:\s+\d+)+              # 一个或多个空格加数字
  | outdate                  # outdate 开头
    (?:\s+[\u4e00-\u9fff]+)+ # 一个或多个空格加中文词（至少一个）
  | alias                    # alias 开头
    (?:\s+[\u4e00-\u9fff]+){2} # 两个中文词
    (?:\s+\d+)*              # 可选数字序列
)$